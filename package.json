{
  "name": "dom-mutation-tracker",
  "version": "1.0.0",
  "description": "A typed, framework-agnostic DOM mutation tracker for development workflows.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.js"
    },
    "./panel": {
      "import": {
        "types": "./dist/panel.d.ts",
        "default": "./dist/panel.js"
      },
      "require": {
        "types": "./dist/panel.d.cts",
        "default": "./dist/panel.cjs"
      },
      "default": "./dist/panel.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "scripts": {
    "build": "npm run clean && tsdown",
    "benchmark": "node scripts/benchmark.mjs",
    "clean": "node --eval \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "npm run build && node --test test/dom-mutation-tracker.test.ts",
    "test:browser": "npm run build && playwright test",
    "test:browser:install": "playwright install chromium",
    "test:package": "npm run build && node scripts/smoke-package.mjs",
    "test:production": "npm run build && node scripts/verify-production-exclusion.mjs",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "verify": "npm run typecheck && npm test && npm run test:browser && npm run test:package && npm run test:production",
    "prepack": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/norbraet/dom-mutation-tracker.git"
  },
  "author": "Norbert Balaž",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/norbraet/dom-mutation-tracker/issues"
  },
  "homepage": "https://github.com/norbraet/dom-mutation-tracker#readme",
  "engines": {
    "node": ">=22.19"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/jsdom": "^28.0.3",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "3.9.4",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
